rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Game Document ────────────────────────────────────────
    match /games/{gameId} {
      // Anyone authenticated can read the game doc (public state)
      allow read: if request.auth != null;

      // Anyone authenticated can create a game
      allow create: if request.auth != null
        && request.resource.data.status == 'lobby'
        && request.resource.data.hostId == request.auth.uid;

      // Update rules:
      // 1) Existing players can always update (turn actions, start game, etc.)
      // 2) New players can update IF the game is in 'lobby' status AND
      //    they are being added to playerOrder (joining)
      allow update: if request.auth != null
        && (
          request.auth.uid in resource.data.playerOrder
          || (
            resource.data.status == 'lobby'
            && request.auth.uid in request.resource.data.playerOrder
          )
        );

      allow delete: if false;

      // ─── Players Sub-collection ─────────────────────────────
      match /players/{playerId} {
        // Anyone authenticated can read player info (names, seats)
        allow read: if request.auth != null;

        // A player can create their own player doc
        allow create: if request.auth != null
          && request.auth.uid == playerId;

        // Any authenticated user can update player docs
        // (needed for host to update seat indices, presence, etc.)
        allow update: if request.auth != null;

        allow delete: if false;
      }

      // ─── Private Player Data ────────────────────────────────
      match /private/{playerId} {
        // Any authenticated player in the game can read private data.
        // This is needed for Queen (swap two cards across players) and
        // Joker (shuffle another player's cards) power transactions.
        // Client-side subscription only subscribes to own private doc,
        // so other players' hands are not exposed in the UI — they are
        // only accessed server-side within Firestore transactions.
        allow read: if request.auth != null;

        // Any authenticated player can create/update private docs
        // (needed for: joining creates own doc, startGame deals to all,
        //  draw/swap/peek updates own doc via transactions)
        // Client transaction logic enforces correctness.
        allow create: if request.auth != null;
        allow update: if request.auth != null;

        allow delete: if false;
      }

      // ─── Reveals (each player writes their own hand at game end) ──
      match /reveals/{playerId} {
        // Anyone can read reveals (they're shown on the results screen)
        allow read: if request.auth != null;

        // A player can only create/update their own reveal
        allow create, update: if request.auth != null
          && request.auth.uid == playerId;

        allow delete: if false;
      }

      // ─── Internal Docs (draw pile) ─────────────────────────────
      match /internal/{docId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
